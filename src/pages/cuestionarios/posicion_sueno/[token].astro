                        <span id="total-valor" class="text-2xl font-extrabold text-indigo-600">0%</span>
                    </div>
                    <div class="mt-2 h-2 bg-indigo-100 rounded-full overflow-hidden">
                        <div id="total-barra" class="h-full bg-indigo-500 rounded-full transition-all duration-300" style="width: 0%"></div>
                    </div>
                    <p id="total-mensaje" class="text-xs text-indigo-500 mt-1"></p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                    <div class="posicion-card bg-white rounded-2xl border-2 border-gray-200 overflow-hidden transition-all duration-200 hover:border-indigo-300 hover:shadow-md hover:shadow-indigo-900/5" data-posicion="supina">
                        <label class="flex items-start gap-4 p-5 cursor-pointer">
                            <div class="mt-0.5">
                                <input type="checkbox" name="pos_supina" value="si" class="posicion-checkbox sr-only" />
                                <div class="checkbox-custom w-6 h-6 rounded-lg border-2 border-gray-300 flex items-center justify-center transition-all duration-200">
                                    <svg class="check-icon w-4 h-4 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                    </svg>
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-bold text-gray-900 text-base">Supina</p>
                                <p class="text-sm text-gray-500 mt-0.5">Boca arriba</p>
                                <div class="mt-4 flex justify-center">
                                    <svg viewBox="0 0 180 90" width="160" height="80" xmlns="http://www.w3.org/2000/svg" aria-label="Posición supina: boca arriba">
                                        <rect x="5" y="68" width="170" height="8" rx="3" fill="#e0e7ff" stroke="#a5b4fc" stroke-width="1.5"/>
                                        <rect x="5" y="60" width="170" height="10" rx="3" fill="#eef2ff" stroke="#c7d2fe" stroke-width="1"/>
                                        <ellipse cx="155" cy="62" rx="18" ry="6" fill="#c7d2fe" stroke="#818cf8" stroke-width="1.2"/>
                                        <rect x="55" y="50" width="70" height="14" rx="7" fill="#818cf8"/>¿
                                        <circle cx="145" cy="57" r="9" fill="#818cf8"/>
                                        <rect x="25" y="52" width="32" height="10" rx="5" fill="#818cf8"/>
                                        <rect x="55" y="55" width="10" height="18" rx="5" fill="#6366f1" transform="rotate(-10 60 64)"/>
                                        <rect x="115" y="55" width="10" height="18" rx="5" fill="#6366f1" transform="rotate(10 120 64)"/>
                                        <ellipse cx="18" cy="57" rx="9" ry="5" fill="#6366f1"/>
                                    </svg>
                                </div>
                            </div>
                        </label>
                        <div class="porcentaje-field hidden px-5 pb-5 pt-0">
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                ¿Qué porcentaje de la noche duerme en esta posición?
                            </label>
                            <div class="relative">
                                <input
                                    type="number"
                                    name="pct_supina"
                                    min="1" max="100"
                                    placeholder="0"
                                    class="porcentaje-input w-full border-2 border-indigo-200 focus:border-indigo-500 rounded-xl px-4 py-3 pr-12 text-lg font-bold text-gray-900 outline-none transition-colors"
                                />
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold text-lg">%</span>
                            </div>
                        </div>
                    </div>

                    <div class="posicion-card bg-white rounded-2xl border-2 border-gray-200 overflow-hidden transition-all duration-200 hover:border-indigo-300 hover:shadow-md hover:shadow-indigo-900/5" data-posicion="lateral_izq">
                        <label class="flex items-start gap-4 p-5 cursor-pointer">
                            <div class="mt-0.5">
                                <input type="checkbox" name="pos_lateral_izq" value="si" class="posicion-checkbox sr-only" />
                                <div class="checkbox-custom w-6 h-6 rounded-lg border-2 border-gray-300 flex items-center justify-center transition-all duration-200">
                                    <svg class="check-icon w-4 h-4 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                    </svg>
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-bold text-gray-900 text-base">Lateral Izquierda</p>
                                <p class="text-sm text-gray-500 mt-0.5">De lado, sobre el lado izquierdo</p>
                                <div class="mt-4 flex justify-center">
                                    <svg viewBox="0 0 180 90" width="160" height="80" xmlns="http://www.w3.org/2000/svg" aria-label="Posición lateral izquierda">
                                        <rect x="5" y="68" width="170" height="8" rx="3" fill="#e0e7ff" stroke="#a5b4fc" stroke-width="1.5"/>
                                        <rect x="5" y="60" width="170" height="10" rx="3" fill="#eef2ff" stroke="#c7d2fe" stroke-width="1"/>
                                        <ellipse cx="155" cy="62" rx="18" ry="6" fill="#c7d2fe" stroke="#818cf8" stroke-width="1.2"/>
                                        <ellipse cx="88" cy="56" rx="38" ry="9" fill="#818cf8"/>
                                        <circle cx="143" cy="56" r="9" fill="#818cf8"/>
                                        <rect x="128" y="52" width="10" height="8" rx="4" fill="#818cf8"/>
                                        <path d="M95 50 Q85 38 75 44" stroke="#6366f1" stroke-width="8" fill="none" stroke-linecap="round"/>
                                        <path d="M80 60 Q70 65 60 63" stroke="#4f46e5" stroke-width="7" fill="none" stroke-linecap="round"/>
                                        <path d="M50 55 Q38 58 30 65" stroke="#818cf8" stroke-width="10" fill="none" stroke-linecap="round"/>
                                        <path d="M50 60 Q38 63 32 70" stroke="#a5b4fc" stroke-width="8" fill="none" stroke-linecap="round"/>
                                        <ellipse cx="22" cy="66" rx="8" ry="5" fill="#6366f1" transform="rotate(-10 22 66)"/>
                                    </svg>
                                </div>
                            </div>
                        </label>
                        <div class="porcentaje-field hidden px-5 pb-5 pt-0">
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                ¿Qué porcentaje de la noche duerme en esta posición?
                            </label>
                            <div class="relative">
                                <input
                                    type="number"
                                    name="pct_lateral_izq"
                                    min="1" max="100"
                                    placeholder="0"
                                    class="porcentaje-input w-full border-2 border-indigo-200 focus:border-indigo-500 rounded-xl px-4 py-3 pr-12 text-lg font-bold text-gray-900 outline-none transition-colors"
                                />
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold text-lg">%</span>
                            </div>
                        </div>
                    </div>

                    <div class="posicion-card bg-white rounded-2xl border-2 border-gray-200 overflow-hidden transition-all duration-200 hover:border-indigo-300 hover:shadow-md hover:shadow-indigo-900/5" data-posicion="lateral_der">
                        <label class="flex items-start gap-4 p-5 cursor-pointer">
                            <div class="mt-0.5">
                                <input type="checkbox" name="pos_lateral_der" value="si" class="posicion-checkbox sr-only" />
                                <div class="checkbox-custom w-6 h-6 rounded-lg border-2 border-gray-300 flex items-center justify-center transition-all duration-200">
                                    <svg class="check-icon w-4 h-4 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                    </svg>
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-bold text-gray-900 text-base">Lateral Derecha</p>
                                <p class="text-sm text-gray-500 mt-0.5">De lado, sobre el lado derecho</p>
                                <div class="mt-4 flex justify-center">
                                    <svg viewBox="0 0 180 90" width="160" height="80" xmlns="http://www.w3.org/2000/svg" aria-label="Posición lateral derecha">
                                        <rect x="5" y="68" width="170" height="8" rx="3" fill="#e0e7ff" stroke="#a5b4fc" stroke-width="1.5"/>
                                        <rect x="5" y="60" width="170" height="10" rx="3" fill="#eef2ff" stroke="#c7d2fe" stroke-width="1"/>
                                        <ellipse cx="25" cy="62" rx="18" ry="6" fill="#c7d2fe" stroke="#818cf8" stroke-width="1.2"/>
                                        <circle cx="37" cy="56" r="9" fill="#818cf8"/>
                                        <rect x="42" y="52" width="10" height="8" rx="4" fill="#818cf8"/>
                                        <ellipse cx="92" cy="56" rx="38" ry="9" fill="#818cf8"/>
                                        <path d="M85 50 Q95 38 105 44" stroke="#6366f1" stroke-width="8" fill="none" stroke-linecap="round"/>
                                        <path d="M100 60 Q110 65 120 63" stroke="#4f46e5" stroke-width="7" fill="none" stroke-linecap="round"/>
                                        <path d="M130 55 Q142 58 150 65" stroke="#818cf8" stroke-width="10" fill="none" stroke-linecap="round"/>
                                        <path d="M130 60 Q142 63 148 70" stroke="#a5b4fc" stroke-width="8" fill="none" stroke-linecap="round"/>
                                        <ellipse cx="158" cy="66" rx="8" ry="5" fill="#6366f1" transform="rotate(10 158 66)"/>
                                    </svg>
                                </div>
                            </div>
                        </label>
                        <div class="porcentaje-field hidden px-5 pb-5 pt-0">
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                ¿Qué porcentaje de la noche duerme en esta posición?
                            </label>
                            <div class="relative">
                                <input
                                    type="number"
                                    name="pct_lateral_der"
                                    min="1" max="100"
                                    placeholder="0"
                                    class="porcentaje-input w-full border-2 border-indigo-200 focus:border-indigo-500 rounded-xl px-4 py-3 pr-12 text-lg font-bold text-gray-900 outline-none transition-colors"
                                />
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold text-lg">%</span>
                            </div>
                        </div>
                    </div>

                    <div class="posicion-card bg-white rounded-2xl border-2 border-gray-200 overflow-hidden transition-all duration-200 hover:border-indigo-300 hover:shadow-md hover:shadow-indigo-900/5" data-posicion="prona">
                        <label class="flex items-start gap-4 p-5 cursor-pointer">
                            <div class="mt-0.5">
                                <input type="checkbox" name="pos_prona" value="si" class="posicion-checkbox sr-only" />
                                <div class="checkbox-custom w-6 h-6 rounded-lg border-2 border-gray-300 flex items-center justify-center transition-all duration-200">
                                    <svg class="check-icon w-4 h-4 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                    </svg>
                                </div>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-bold text-gray-900 text-base">Prona</p>
                                <p class="text-sm text-gray-500 mt-0.5">Boca abajo</p>
                                <div class="mt-4 flex justify-center">
                                    <svg viewBox="0 0 180 90" width="160" height="80" xmlns="http://www.w3.org/2000/svg" aria-label="Posición prona: boca abajo">
                                        <rect x="5" y="68" width="170" height="8" rx="3" fill="#e0e7ff" stroke="#a5b4fc" stroke-width="1.5"/>
                                        <rect x="5" y="60" width="170" height="10" rx="3" fill="#eef2ff" stroke="#c7d2fe" stroke-width="1"/>
                                        <ellipse cx="152" cy="63" rx="14" ry="5" fill="#c7d2fe" stroke="#818cf8" stroke-width="1"/>
                                        <rect x="55" y="50" width="70" height="14" rx="7" fill="#818cf8"/>
                                        <ellipse cx="148" cy="56" rx="10" ry="8" fill="#818cf8"/>
                                        <rect x="22" y="52" width="35" height="10" rx="5" fill="#818cf8"/>
                                        <path d="M125 50 Q138 38 148 44" stroke="#6366f1" stroke-width="8" fill="none" stroke-linecap="round"/>
                                        <path d="M55 50 Q42 38 35 44" stroke="#6366f1" stroke-width="8" fill="none" stroke-linecap="round"/>
                                        <ellipse cx="13" cy="57" rx="8" ry="5" fill="#6366f1"/>
                                    </svg>
                                </div>
                            </div>
                        </label>
                        <div class="porcentaje-field hidden px-5 pb-5 pt-0">
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                ¿Qué porcentaje de la noche duerme en esta posición?
                            </label>
                            <div class="relative">
                                <input
                                    type="number"
                                    name="pct_prona"
                                    min="1" max="100"
                                    placeholder="0"
                                    class="porcentaje-input w-full border-2 border-indigo-200 focus:border-indigo-500 rounded-xl px-4 py-3 pr-12 text-lg font-bold text-gray-900 outline-none transition-colors"
                                />
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 font-bold text-lg">%</span>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="pt-10">
                    <button type="button" id="btn-pre-submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-indigo-900/20 hover:scale-[1.02] active:scale-95 text-lg cursor-pointer">
                        Guardar y Finalizar
                    </button>
                </div>
            </form>

            <dialog id="modal-confirm" class="m-auto p-0 rounded-2xl max-w-md w-full shadow-2xl backdrop:bg-black/80 backdrop:backdrop-blur-sm bg-transparent">
                <div class="bg-white p-6 w-full">
                    <div class="text-center">
                        <div class="w-16 h-16 bg-yellow-100 text-yellow-600 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 mb-2">¿Estás seguro de enviar?</h3>
                        <p class="text-gray-500 text-sm mb-6">
                            Una vez enviadas tus respuestas, <strong>no podrás modificarlas ni volver a contestar</strong> este cuestionario.
                            Por favor verifica que todo esté correcto.
                        </p>
                        <div class="grid grid-cols-2 gap-3">
                            <button id="btn-cancel" class="py-3 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-xl transition-colors cursor-pointer">
                                Revisar
                            </button>
                            <button id="btn-confirm-final" class="py-3 px-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/30 transition-colors cursor-pointer">
                                Sí, Enviar
                            </button>
                        </div>
                    </div>
                </div>
            </dialog>
        </>
    )}

</LayoutCuestionario>

<script is:inline>
    // ── Checkboxes interactivos ──────────────────────────────────────────────
    const cards = document.querySelectorAll('.posicion-card');

    cards.forEach(card => {
        const checkbox = card.querySelector('.posicion-checkbox');
        const checkboxCustom = card.querySelector('.checkbox-custom');
        const checkIcon = card.querySelector('.check-icon');
        const porcentajeField = card.querySelector('.porcentaje-field');
        const porcentajeInput = card.querySelector('.porcentaje-input');

        checkbox.addEventListener('change', () => {
            if (checkbox.checked) {
                // Estado: seleccionado
                card.classList.remove('border-gray-200');
                card.classList.add('border-indigo-500', 'shadow-md', 'shadow-indigo-900/10');
                checkboxCustom.classList.remove('border-gray-300');
                checkboxCustom.classList.add('bg-indigo-600', 'border-indigo-600');
                checkIcon.classList.remove('hidden');
                porcentajeField.classList.remove('hidden');
                porcentajeInput.required = true;
            } else {
                // Estado: deseleccionado
                card.classList.add('border-gray-200');
                card.classList.remove('border-indigo-500', 'shadow-md', 'shadow-indigo-900/10');
                checkboxCustom.classList.add('border-gray-300');
                checkboxCustom.classList.remove('bg-indigo-600', 'border-indigo-600');
                checkIcon.classList.add('hidden');
                porcentajeField.classList.add('hidden');
                porcentajeInput.required = false;
                porcentajeInput.value = '';
            }
            actualizarTotal();
        });
    });

    // ── Contador de porcentaje total ─────────────────────────────────────────
    const totalDisplay = document.getElementById('total-display');
    const totalValor = document.getElementById('total-valor');
    const totalBarra = document.getElementById('total-barra');
    const totalMensaje = document.getElementById('total-mensaje');

    function actualizarTotal() {
        const inputs = document.querySelectorAll('.porcentaje-input:not([style*="display:none"])');
        const visibleInputs = Array.from(document.querySelectorAll('.porcentaje-field:not(.hidden) .porcentaje-input'));

        if (visibleInputs.length === 0) {
            totalDisplay.classList.add('hidden');
            return;
        }

        totalDisplay.classList.remove('hidden');

        let suma = 0;
        visibleInputs.forEach(inp => {
            suma += parseInt(inp.value || '0', 10);
        });

        totalValor.textContent = suma + '%';
        const pct = Math.min(suma, 100);
        totalBarra.style.width = pct + '%';

        if (suma === 100) {
            totalBarra.classList.remove('bg-indigo-500', 'bg-red-500');
            totalBarra.classList.add('bg-emerald-500');
            totalValor.classList.remove('text-indigo-600', 'text-red-600');
            totalValor.classList.add('text-emerald-600');
            totalMensaje.textContent = '✓ El total es 100%. Puedes continuar.';
            totalMensaje.className = 'text-xs text-emerald-600 mt-1 font-medium';
        } else if (suma > 100) {
            totalBarra.classList.remove('bg-indigo-500', 'bg-emerald-500');
            totalBarra.classList.add('bg-red-500');
            totalValor.classList.remove('text-indigo-600', 'text-emerald-600');
            totalValor.classList.add('text-red-600');
            totalMensaje.textContent = `El total supera 100% por ${suma - 100}%. Ajusta los valores.`;
            totalMensaje.className = 'text-xs text-red-500 mt-1 font-medium';
        } else {
            totalBarra.classList.remove('bg-emerald-500', 'bg-red-500');
            totalBarra.classList.add('bg-indigo-500');
            totalValor.classList.remove('text-emerald-600', 'text-red-600');
            totalValor.classList.add('text-indigo-600');
            const falta = 100 - suma;
            totalMensaje.textContent = `Falta ${falta}% para completar el 100%.`;
            totalMensaje.className = 'text-xs text-indigo-500 mt-1';
        }
    }

    // Actualiza el contador al escribir en cualquier input de porcentaje
    document.querySelectorAll('.porcentaje-input').forEach(inp => {
        inp.addEventListener('input', actualizarTotal);
    });

    // ── Modal de confirmación ────────────────────────────────────────────────
    const form = document.getElementById('cuestionario-form');
    const btnPre = document.getElementById('btn-pre-submit');
    const modal = document.getElementById('modal-confirm');
    const btnCancel = document.getElementById('btn-cancel');
    const btnConfirmFinal = document.getElementById('btn-confirm-final');

    if (btnPre) {
        btnPre.addEventListener('click', () => {
            // Verificar que al menos una posición esté seleccionada
            const checkedBoxes = document.querySelectorAll('.posicion-checkbox:checked');
            if (checkedBoxes.length === 0) {
                alert('Por favor selecciona al menos una posición al dormir.');
                return;
            }

            // Verificar que el total sea 100%
            const visibleInputs = Array.from(document.querySelectorAll('.porcentaje-field:not(.hidden) .porcentaje-input'));
            let suma = 0;
            visibleInputs.forEach(inp => { suma += parseInt(inp.value || '0', 10); });

            if (suma !== 100) {
                alert(`La suma de los porcentajes debe ser exactamente 100%. Actualmente es ${suma}%.`);
                return;
            }

            // Validación nativa del formulario
            if (form.reportValidity()) {
                modal.showModal();
            }
        });
    }

    if (btnCancel) {
        btnCancel.addEventListener('click', () => { modal.close(); });
    }

    if (btnConfirmFinal) {
        btnConfirmFinal.addEventListener('click', () => {
            btnConfirmFinal.innerHTML = '<span class="animate-pulse">Enviando...</span>';
            btnConfirmFinal.disabled = true;
            form.submit();
        });
    }

    modal.addEventListener('click', (e) => {
        const d = modal.getBoundingClientRect();
        if (e.clientX < d.left || e.clientX > d.right || e.clientY < d.top || e.clientY > d.bottom) {
            modal.close();
        }
    });
</script>