---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import ReturnButton from '../components/ReturnButton.astro';
import ManualCard from '../components/ManualCard.astro';
import ManualModal from '../components/ManualModal.astro';
import { supabase } from '../lib/supabase';

export interface Manual {
    id: string;
    titulo: string;
    descripcion: string;
    url: string;
    tipo: "CANVA" | "WORD" | "DRIVE" | "VIDEO" | "EXCEL" | "WEB";
}

const { data: manuales, error } = await supabase
    .from('manuales')
    .select('*')
    .order('created_at', { ascending: true });

if (error) {
    console.error('[manuales] Error al obtener manuales:', error.message);
}

const listaManuales: Manual[] = manuales ?? [];
---

<Layout title="Manuales | Lab-Somno">
    <Icon />
    <ReturnButton href="/dashboard" text="Volver al dashboard" />
    <div class="min-h-screen p-4 md:p-10">

        <div class="max-w-7xl mx-auto mb-12 text-center relative">
            <h1 class="max-md:max-w-xs max-md:pt-10 max-lg:max-w-xl text-4xl md:text-6xl font-extrabold text-balance text-center">
                Biblioteca del <span class="bg-gradient-to-r from-blue-500 via-blue-300 to-blue-600 bg-clip-text text-transparent drop-shadow-[0_0_15px_rgba(59,130,246,0.5)]">sueño</span>
            </h1>
            <p class="pt-5 text-lg text-gray-400">
                Todos los recursos, guías y documentos necesarios están aquí.
            </p>
            <button
                id="btn-agregar-manual"
                class="mt-6 inline-flex items-center gap-2 rounded-xl border border-blue-500/30 bg-blue-500/10 px-5 py-2.5 text-sm font-semibold text-blue-400 transition hover:bg-blue-500/20 hover:text-blue-300 cursor-pointer"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Agregar manual
            </button>
        </div>

        <div
            id="manuales-grid"
            class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
        >
            {listaManuales.map((manual, index) => (
                <div
                    class="manual-card-wrapper relative h-full group/wrapper"
                    data-id={manual.id}
                    data-titulo={manual.titulo}
                    data-descripcion={manual.descripcion}
                    data-url={manual.url}
                    data-tipo={manual.tipo}
                >
                    <ManualCard
                        titulo={manual.titulo}
                        descripcion={manual.descripcion}
                        url={manual.url}
                        tipo={manual.tipo}
                        delay={index * 100}
                    />

                    <button
                        class="btn-editar-manual absolute bottom-3 right-3 z-20 flex items-center gap-1.5 rounded-lg border border-white/10 bg-gray-900/90 px-2.5 py-1.5 text-xs font-medium text-gray-400 opacity-0 backdrop-blur-sm transition-all group-hover/wrapper:opacity-100 hover:border-blue-500/40 hover:text-blue-400 cursor-pointer"
                        aria-label="Editar manual"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 3.487a2.25 2.25 0 1 1 3.182 3.182L7.5 19.213l-4 1 1-4 12.362-12.726z" />
                        </svg>
                        Editar
                    </button>
                </div>
            ))}
        </div>
    </div>

    <ManualModal />
</Layout>

<style>
    @keyframes enter-up {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .animate-enter-up {
        animation: enter-up 0.6s ease-out forwards;
    }
</style>

<script>
    type TipoManual = "CANVA" | "WORD" | "DRIVE" | "VIDEO" | "EXCEL" | "WEB";
    interface Manual { id: string; titulo: string; descripcion: string; url: string; tipo: TipoManual; }

    document.getElementById("btn-agregar-manual")?.addEventListener("click", () => {
        document.dispatchEvent(new CustomEvent("modal:abrir", { detail: {} }));
    });

    document.querySelectorAll<HTMLElement>(".manual-card-wrapper").forEach(wrapper => {
        wrapper.querySelector(".btn-editar-manual")?.addEventListener("click", () => {
            const { id, titulo, descripcion, url, tipo } = wrapper.dataset;
            document.dispatchEvent(new CustomEvent("modal:abrir", {
                detail: {
                    manual: { id, titulo, descripcion, url, tipo: tipo as TipoManual }
                }
            }));
        });
    });

    document.addEventListener("manual:guardado", () => {
        window.location.reload();
    });

    document.addEventListener("manual:eliminado", (e: Event) => {
        const { id } = (e as CustomEvent<{ id: string }>).detail;
        document.querySelector<HTMLElement>(`.manual-card-wrapper[data-id="${id}"]`)?.remove();
    });
</script>